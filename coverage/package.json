    "type": "module",
    "scripts": {
        "build": "npx tsc",
        "watch": "npx tsc --watch",
        "update": "node --enable-source-maps dist/bin/update.js",
        "start": "nodemon --enable-source-maps dist/bin/server.js ./dist-dev/client/",
        "build-client": "npx tsc && npx webpack --mode development --color --config ./dist/webpack-configs/client.js",
        "watch-client": "npx tsc && npx webpack --watch --progress --mode development --color --config ./dist/webpack-configs/client.js",
        "build-client:prod": "npx tsc && npx webpack --mode production --color --config ./dist/webpack-configs/client.js"
    },
